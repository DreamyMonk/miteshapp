<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ uses the SplashScreen API: it only allows a background
         color + a centered icon (a full image like flash.png is not permitted
         by the OS). We set the background to cream + the app icon so it blends
         into the in-app flash screen. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/ik_cream</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/ik_cream</item>
    </style>
</resources>
